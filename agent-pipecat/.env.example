# Pipecat PoC Agent — Environment Variables
# Copy to .env and fill in your API keys

# LiveKit Configuration (same as main agent)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram STT (Nova-3)
# Get your API key at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Gemini 2.5 Flash (LLM)
# Get your API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# ElevenLabs TTS (Flash v2.5)
# Get your API key at https://elevenlabs.io
ELEVEN_API_KEY=your_eleven_api_key
ELEVEN_VOICE_ID=your_eleven_voice_id

# OpenAI (for shared emotion analyzer + AI coach modules)
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Supabase Configuration (same as main agent)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Simli Avatar
# Get your API key at https://www.simli.com
SIMLI_API_KEY=your_simli_api_key
SIMLI_FACE_ID=your_simli_face_id
