# LiveKit Configuration
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# OpenAI Configuration
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Google Gemini (LEGACY - disabled, kept for reference)
# GOOGLE_API_KEY=your_google_api_key

# Avatar Configuration — Simli (default)
# Get your API key at https://www.simli.com
SIMLI_API_KEY=your_simli_api_key
SIMLI_FACE_ID=your_simli_face_id
# Comma-separated list for random selection (optional)
# SIMLI_FACE_IDS=face1,face2,face3

# Simli avatar tuning (optional — sensible defaults provided)
# SIMLI_EMOTION_ID=                   # UUID, auto-maps from scenario difficulty if unset
# SIMLI_MAX_SESSION_LENGTH=300        # Max avatar duration in seconds (default: 300 = 5 min)
# SIMLI_MAX_IDLE_TIME=120             # Max silence before avatar disconnects (default: 120 = 2 min)
# Emotion reference: natural=b4fcff6b..., happy=92f24a0c..., angry=668f65f6..., doubtful=7f5e31e8...

# ElevenLabs TTS — Half-Cascade mode (optional, currently disabled)
# Can enable lower latency with emotional voice synthesis
# Get your API key at https://elevenlabs.io
# ELEVEN_API_KEY=your_eleven_api_key
# ELEVEN_VOICE_ID=your_eleven_voice_id

# Deepgram STT — Required for EOU turn detection model
# Get your API key at https://console.deepgram.com
# DEEPGRAM_API_KEY=your_deepgram_api_key

# EOU Turn Detection — Reduces false interruptions by ~39%
# Requires DEEPGRAM_API_KEY to be set
# ENABLE_EOU_MODEL=true

# Legacy avatar providers (optional)
# HEDRA_API_KEY=your_hedra_api_key
# HEDRA_AVATAR_ID=your_hedra_avatar_id
# LIVEAVATAR_API_KEY=your_liveavatar_api_key
# LIVEAVATAR_AVATAR_ID=your_liveavatar_avatar_id

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
