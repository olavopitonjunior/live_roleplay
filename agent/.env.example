# LiveKit Configuration
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Google Gemini Configuration
# Get your API key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key

# Avatar Configuration
# Simli (default)
SIMLI_API_KEY=your_simli_api_key
SIMLI_FACE_ID=your_simli_face_id

# HeyGen/LiveAvatar (optional)
# Get your API key at https://app.liveavatar.com
LIVEAVATAR_API_KEY=your_liveavatar_api_key
LIVEAVATAR_AVATAR_ID=your_liveavatar_avatar_id

# Hedra (optional)
# Get your API key at https://www.hedra.com
HEDRA_API_KEY=your_hedra_api_key
HEDRA_AVATAR_ID=your_hedra_avatar_id

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
